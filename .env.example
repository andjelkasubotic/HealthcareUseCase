# Copy to .env and fill in values:
#   cp .env.example .env

# LLM_MODE: dummy = keyword/template steps (no API) | openai = real API for classify/extract/draft
LLM_MODE=dummy

# Required when LLM_MODE=openai
OPENAI_API_KEY=

# Per-task OpenAI models (only used when LLM_MODE=openai; ignored in dummy mode)
# classify: fast/cheap          → GPT-4.1 mini
# extract: structured fields    → GPT-4.1
# draft: higher-quality text    → GPT-5.1
# judge: reasoning / QA check   → GPT-5.2
# embed: FAQ retrieval vectors  → text-embedding-3-small
LLM_CLASSIFY_MODEL=gpt-4.1-mini
LLM_CLASSIFY_TEMPERATURE=0

LLM_EXTRACT_MODEL=gpt-4.1
LLM_EXTRACT_TEMPERATURE=0

LLM_DRAFT_MODEL=gpt-5.1
LLM_DRAFT_TEMPERATURE=0.3

LLM_JUDGE_MODEL=gpt-5.2
LLM_JUDGE_TEMPERATURE=0

LLM_EMBED_MODEL=text-embedding-3-small

# FAQ knowledge base (RAG for draft grounding)
KB_FAQ_PATH=data/kb/dermatology_faq.txt
KB_TOP_K=3
